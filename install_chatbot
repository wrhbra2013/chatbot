import { makeWASocket, useMultiFileAuthState, DisconnectReason } from '@whiskeysockets/baileys';
import qrcode from 'qrcode-terminal';
import { SocksProxyAgent } from 'socks-proxy-agent';

const API_BASE = process.env.API_URL || 'http://localhost:3000';
const API_TOKEN = process.env.API_TOKEN || 'ecommerce-api-token';
const API_WRITE_KEY = process.env.API_WRITE_KEY || API_TOKEN;

let carrinhosCache = {};
const userSession = {};

async function api(m, p, b) {
  const o = { method: m, headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + API_TOKEN } };
  if (b) { o.body = JSON.stringify(b); o.headers['X-Write-Key'] = API_WRITE_KEY; }
  return (await fetch(API_BASE + p, o)).json();
}
function fmt(v) { return 'R$ ' + v.toFixed(2).replace('.', ','); }
function esc(s) { return String(s).replace(/([*_~`>#+\-=|{}.!])/g, '\\$1'); }

function menuPrincipal(n) {
  return '\u{1F3EA} *Menu Principal*\n' + (n ? 'Ola, ' + esc(n) + '!' : 'Bem-vindo!') + '\n\n1. \u{1F4E6} Ver Produtos\n2. \u{1F6D2} Meu Carrinho\n3. \u{1F464} Meu Cadastro\n4. \u2705 Finalizar Pedido\n5. \u{1F5D1}\uFE0F Limpar Carrinho\n6. \u2753 Ajuda\n\nDigite o numero da opcao desejada.';
}

async function menuCategorias(j) {
  try {
    const r = await fetch(API_BASE + '/data/produtos');
    const ps = await r.json();
    const cs = {}; ps.forEach(p => { if (p.categoria) cs[p.categoria] = true; });
    const l = Object.keys(cs).sort();
    let m = '\u{1F4E6} *Categorias*\n\n';
    l.forEach((c, i) => { m += (i + 1) + '. ' + c.charAt(0).toUpperCase() + c.slice(1) + '\n'; });
    m += '\n0. \u{1F519} Voltar\n\nDigite o numero da categoria.';
    userSession[j] = { menu: 'categorias', cats: l };
    return m;
  } catch (e) { return 'Erro ao carregar categorias.'; }
}

async function listarProdutos(j, cat, pag = 0) {
  const p = cat ? '?categoria=' + encodeURIComponent(cat) + '&limit=10&offset=' + (pag * 10) : '?limit=10&offset=' + (pag * 10);
  try {
    const r = await api('GET', '/api/produtos' + p);
    const l = r.data || [];
    if (!l.length) return 'Nenhum produto encontrado' + (cat ? ' em ' + esc(cat) : '') + '.';
    let m = '*\u{1F4E6} Produtos' + (cat ? ' - ' + esc(cat) : '') + '*\n\n';
    l.forEach((p, i) => {
      m += (pag * 10 + i + 1) + '. *' + esc(p.nome) + '*\n   ID: ' + p.id + ' | ' + fmt(parseFloat(p.preco));
      if (p.estoque > 0) m += ' | Estq: ' + p.estoque;
      m += '\n\n';
    });
    m += 'Para comprar: *comprar <id> [qtd]*\nPara detalhes: *detalhe <id>*\n';
    if (l.length === 10) m += '\nProxima pagina: *mais*';
    m += '\n\n0. \u{1F519} Voltar';
    return m;
  } catch (e) { return 'Erro ao buscar produtos.'; }
}

async function msgCarrinho(j) {
  const c = carrinhosCache[j] || [];
  if (!c.length) return '\u{1F6D2} *Carrinho vazio!*\n\nAdicione produtos com *comprar <id>* ou pelo site.\n\n0. \u{1F519} Voltar';
  const t = c.reduce((s, i) => s + parseFloat(i.preco) * i.qtd, 0);
  return '\u{1F6D2} *Carrinho*\n\n' + c.map((i, idx) => (idx + 1) + '. ' + esc(i.nome) + ' x' + i.qtd + ' = ' + fmt(parseFloat(i.preco) * i.qtd)).join('\n') + '\n\n*Total:* ' + fmt(t) + '\n\n4. \u2705 Finalizar\n5. \u{1F5D1}\uFE0F Limpar\n\n0. \u{1F519} Voltar';
}

async function verCadastro(j) {
  try { const r = await api('GET', '/api/clientes/' + encodeURIComponent(j)); return r.success ? r.data : null; } catch (e) { return null; }
}

function formatCadastro(c) {
  return '\u{1F464} *Meu Cadastro*\n\n*Nome:* ' + esc(c.nome) + '\n*Telefone:* ' + esc(c.telefone) + (c.endereco ? '\n*Endereco:* ' + esc(c.endereco) : '') + (c.cidade ? '\n*Cidade:* ' + esc(c.cidade) : '') + '\n\n1. \u270F\uFE0F Editar nome\n2. \u270F\uFE0F Editar endereco\n3. \u270F\uFE0F Editar cidade\n4. \u274C Excluir cadastro\n0. \u{1F519} Voltar';
}

async function enviar(s, j, t) { await s.sendMessage(j, { text: t }); }

async function startBot() {
  const { state, saveCreds } = await useMultiFileAuthState('auth_info');
  const sock = makeWASocket({ auth: state, syncFullHistory: false, browser: ['Ecommerce Bot', 'Chrome', '1.0'], ...(process.env.SOCKS_PROXY ? { agent: new SocksProxyAgent(process.env.SOCKS_PROXY) } : {}) });
  sock.ev.on('creds.update', saveCreds);

  sock.ev.on('connection.update', async (up) => {
    const { connection, lastDisconnect, qr } = up;
    if (qr) {
      qrcode.generate(qr, { small: true });
      const phone = (process.env.PHONE_NUMBER || '').replace(/\D/g, '');
      if (phone) {
        try {
          const code = await sock.requestPairingCode(phone);
          console.log('Pairing code:', code);
          await fetch(API_BASE + '/api/qrcode', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Write-Key': API_WRITE_KEY }, body: JSON.stringify({ qr, pairingCode: code, connected: false }) });
        } catch (e) { console.error('Pairing code error:', e.message); }
      } else {
        try { await fetch(API_BASE + '/api/qrcode', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Write-Key': API_WRITE_KEY }, body: JSON.stringify({ qr, connected: false }) }); } catch (e) {}
      }
    }
    if (connection === 'open') {
      console.log('Chatbot de e-commerce online (Baileys)!');
      try { await fetch(API_BASE + '/api/qrcode', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Write-Key': API_WRITE_KEY }, body: JSON.stringify({ qr: null, connected: true }) }); } catch (e) {}
    }
    if (connection === 'close') {
      const recon = lastDisconnect?.error?.output?.statusCode !== DisconnectReason.loggedOut;
      console.log('Conexao fechada, reconectando:', recon);
      try { await fetch(API_BASE + '/api/qrcode', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Write-Key': API_WRITE_KEY }, body: JSON.stringify({ qr: null, connected: false }) }); } catch (e) {}
      if (recon) { console.log('Tentando reconectar em 10s...'); setTimeout(startBot, 10000); }
    }
  });

  sock.ev.on('messages.upsert', async ({ messages }) => {
    for (const msg of messages) {
      if (msg.key.fromMe || !msg.message) continue;
      const j = msg.key.remoteJid;
      if (j.includes('@g.us')) continue;
      if (!carrinhosCache[j]) carrinhosCache[j] = [];
      const t = (msg.message.conversation || msg.message.extendedTextMessage?.text || '').trim();
      const tl = t.toLowerCase();

      if (tl === 'menu' || tl === 'inicio' || tl === 'oi' || tl === 'ola' || tl === '0' || tl === 'voltar') {
        delete userSession[j]; const c = await verCadastro(j); return enviar(sock, j, menuPrincipal(c ? c.nome : null));
      }
      if (tl === 'ajuda' || tl === '6') return enviar(sock, j, '\u2753 *Ajuda - Comandos*\n\nMenu numerado:\n1 - Ver produtos por categoria\n2 - Ver carrinho\n3 - Meu cadastro (nome, endereco)\n4 - Finalizar pedido\n5 - Limpar carrinho\n6 - Ajuda\n0 - Voltar ao menu\n\nComandos diretos:\n*produtos* - Listar catalogo\n*comprar <id> [qtd]* - Adicionar ao carrinho\n*detalhe <id>* - Detalhes do produto\n*carrinho* - Ver carrinho\n*finalizar* - Confirmar pedido\n*cadastro* - Meu cadastro\n*menu* - Menu principal');
      if (tl === 'produtos' || tl === '1') return enviar(sock, j, await menuCategorias(j));
      if (tl.startsWith('produtos ')) { const cat = tl.slice(9).trim(); userSession[j] = { menu: 'produtos', categoria: cat }; return enviar(sock, j, await listarProdutos(j, cat)); }
      if (tl === 'mais') {
        const s = userSession[j];
        if (!s || s.menu !== 'produtos') return enviar(sock, j, 'Use *produtos* primeiro.');
        s.pagina = (s.pagina || 0) + 1; return enviar(sock, j, await listarProdutos(j, s.categoria, s.pagina));
      }
      if (tl.startsWith('detalhe ')) {
        const id = tl.slice(8).trim(); if (!id) return enviar(sock, j, 'Use: *detalhe <id>*');
        try {
          const r = await api('GET', '/api/produtos/' + encodeURIComponent(id));
          if (!r.success) return enviar(sock, j, 'Produto nao encontrado.');
          const p = r.data;
          let m = '*\u{1F4C4} ' + esc(p.nome) + '*\n\n';
          if (p.descricao) m += esc(p.descricao) + '\n\n';
          m += '*Preco:* ' + fmt(parseFloat(p.preco)) + '\n*Categoria:* ' + esc(p.categoria) + '\n*Estoque:* ' + (p.estoque > 0 ? p.estoque + ' unidades' : 'Indisponivel') + '\n';
          if (p.imagem) m += '\n\u{1F517} ' + p.imagem + '\n';
          m += '\nPara comprar: *comprar ' + esc(p.id) + ' [qtd]*'; return enviar(sock, j, m);
        } catch (e) { return enviar(sock, j, 'Erro ao buscar detalhes.'); }
      }
      if (tl.startsWith('comprar ')) {
        const args = tl.slice(8).trim().split(/\s+/); const id = args[0]; const q = parseInt(args[1]) || 1;
        if (!id) return enviar(sock, j, 'Use: *comprar <id> [qtd]*');
        try {
          const r = await api('GET', '/api/produtos/' + encodeURIComponent(id));
          if (!r.success) return enviar(sock, j, 'Produto nao encontrado.');
          const p = r.data; if (p.estoque < 1) return enviar(sock, j, 'Produto indisponivel no momento.');
          const e = carrinhosCache[j].find(i => i.id === p.id);
          if (e) { e.qtd += q; } else { carrinhosCache[j].push({ id: p.id, nome: p.nome, preco: parseFloat(p.preco), qtd: q, imagem: p.imagem || '', categoria: p.categoria }); }
          return enviar(sock, j, '\u2705 *' + esc(p.nome) + '* x' + q + ' adicionado ao carrinho!\nTotal: ' + fmt(carrinhosCache[j].reduce((s, i) => s + parseFloat(i.preco) * i.qtd, 0)) + '\n\n1. \u{1F4E6} Ver mais produtos\n2. \u{1F6D2} Ver carrinho\n0. \u{1F519} Menu principal');
        } catch (e) { return enviar(sock, j, 'Erro ao adicionar produto.'); }
      }
      if (tl === 'carrinho' || tl === 'ver_carrinho' || tl === '2') return enviar(sock, j, await msgCarrinho(j));
      if (tl === 'cadastro' || tl === '3') {
        const c = await verCadastro(j);
        if (c) return enviar(sock, j, formatCadastro(c));
        userSession[j] = { menu: 'cadastro_aguardando_nome' }; return enviar(sock, j, '\u{1F464} *Novo Cadastro*\n\nVamos criar seu cadastro! Digite seu *nome completo*:\n\n0. \u{1F519} Cancelar');
      }
      if (userSession[j] && userSession[j].menu === 'cadastro_aguardando_nome') {
        if (t.length < 3) return enviar(sock, j, 'Nome invalido. Digite seu nome completo ou 0 para cancelar.');
        userSession[j] = { menu: 'cadastro_aguardando_endereco', nome: t }; return enviar(sock, j, 'Obrigado, ' + esc(t) + '! Agora digite seu *endereco* (rua, numero, bairro):\n\n0. \u{1F519} Cancelar');
      }
      if (userSession[j] && userSession[j].menu === 'cadastro_aguardando_endereco') {
        if (t.length < 5) return enviar(sock, j, 'Endereco invalido. Digite seu endereco ou 0 para cancelar.');
        userSession[j] = { menu: 'cadastro_aguardando_cidade', nome: userSession[j].nome, endereco: t }; return enviar(sock, j, 'Agora digite sua *cidade*:\n\n0. \u{1F519} Cancelar');
      }
      if (userSession[j] && userSession[j].menu === 'cadastro_aguardando_cidade') {
        if (t.length < 2) return enviar(sock, j, 'Cidade invalida. Digite sua cidade ou 0 para cancelar.');
        const d = userSession[j];
        try {
          const r = await api('POST', '/api/clientes', { id: j, nome: d.nome, telefone: j.split('@')[0], endereco: d.endereco, cidade: t });
          if (r.success) { delete userSession[j]; return enviar(sock, j, '\u2705 *Cadastro realizado!*\n\n*Nome:* ' + esc(d.nome) + '\n*Endereco:* ' + esc(d.endereco) + '\n*Cidade:* ' + esc(t) + '\n\n1. \u{1F4E6} Ver produtos\n0. \u{1F519} Menu principal'); }
          return enviar(sock, j, 'Erro ao salvar cadastro.');
        } catch (e) { return enviar(sock, j, 'Erro ao salvar cadastro.'); }
      }
      if (userSession[j] && userSession[j].menu === 'editando_nome') {
        if (t.length < 3) return enviar(sock, j, 'Nome invalido.');
        try { await api('PUT', '/api/clientes/' + encodeURIComponent(j), { nome: t }); delete userSession[j]; return enviar(sock, j, '\u2705 Nome atualizado!\n\n0. \u{1F519} Voltar'); } catch (e) { return enviar(sock, j, 'Erro ao atualizar.'); }
      }
      if (userSession[j] && userSession[j].menu === 'editando_endereco') {
        if (t.length < 5) return enviar(sock, j, 'Endereco invalido.');
        try { await api('PUT', '/api/clientes/' + encodeURIComponent(j), { endereco: t }); delete userSession[j]; return enviar(sock, j, '\u2705 Endereco atualizado!\n\n0. \u{1F519} Voltar'); } catch (e) { return enviar(sock, j, 'Erro ao atualizar.'); }
      }
      if (userSession[j] && userSession[j].menu === 'editando_cidade') {
        if (t.length < 2) return enviar(sock, j, 'Cidade invalida.');
        try { await api('PUT', '/api/clientes/' + encodeURIComponent(j), { cidade: t }); delete userSession[j]; return enviar(sock, j, '\u2705 Cidade atualizada!\n\n0. \u{1F519} Voltar'); } catch (e) { return enviar(sock, j, 'Erro ao atualizar.'); }
      }
      if (userSession[j] && userSession[j].menu === 'confirmar_exclusao') {
        if (tl === 'sim') { try { await api('DELETE', '/api/clientes/' + encodeURIComponent(j)); delete userSession[j]; return enviar(sock, j, '\u2705 Cadastro excluido.\n\n0. \u{1F519} Menu principal'); } catch (e) { return enviar(sock, j, 'Erro ao excluir.'); } }
        return enviar(sock, j, 'Exclusao cancelada.\n\n0. \u{1F519} Voltar');
      }
      if (tl === 'finalizar' || tl === '4') {
        const c = carrinhosCache[j]; if (!c || !c.length) return enviar(sock, j, 'Carrinho vazio!');
        const l = c.map(i => esc(i.nome) + ' x' + i.qtd + ' = ' + fmt(parseFloat(i.preco) * i.qtd)).join('\n');
        const t2 = c.reduce((s, i) => s + parseFloat(i.preco) * i.qtd, 0);
        try { await api('POST', '/api/create', { table: 'pedidos', data: { cliente_id: j, cliente_nome: 'Cliente WhatsApp', cliente_telefone: j.split('@')[0], itens: JSON.stringify(c), total: t2, status: 'pendente', forma_pagamento: 'whatsapp' } }); } catch (e) { console.error('Erro:', e.message); }
        delete carrinhosCache[j]; return enviar(sock, j, '\u2705 *Pedido Confirmado!*\n\n' + l + '\n\n*Total:* ' + fmt(t2) + '\n\nUm atendente entrara em contato.\n\n0. \u{1F519} Menu principal');
      }
      if (tl === 'limpar' || tl === '5') { delete carrinhosCache[j]; return enviar(sock, j, 'Carrinho limpo!\n\n0. \u{1F519} Menu principal'); }
      if (userSession[j] && userSession[j].menu === 'categorias') {
        const idx = parseInt(t) - 1; const cat = userSession[j].cats[idx];
        if (cat) { userSession[j] = { menu: 'produtos', categoria: cat, pagina: 0 }; return enviar(sock, j, await listarProdutos(j, cat)); }
      }
      if (userSession[j] && userSession[j].menu === 'visualizando_cadastro') {
        if (tl === '1') { userSession[j] = { menu: 'editando_nome' }; return enviar(sock, j, 'Digite o novo *nome*:\n\n0. \u{1F519} Cancelar'); }
        if (tl === '2') { userSession[j] = { menu: 'editando_endereco' }; return enviar(sock, j, 'Digite o novo *endereco*:\n\n0. \u{1F519} Cancelar'); }
        if (tl === '3') { userSession[j] = { menu: 'editando_cidade' }; return enviar(sock, j, 'Digite a nova *cidade*:\n\n0. \u{1F519} Cancelar'); }
        if (tl === '4') { userSession[j] = { menu: 'confirmar_exclusao' }; return enviar(sock, j, 'Tem certeza? Digite *sim* ou *nao*.'); }
      }
      enviar(sock, j, 'Nao entendi. Digite *menu* para comecar.');
    }
  });
}
startBot();
BOTEOF

cp "$INSTALL_DIR/index.js" "$INSTALL_DIR/bot/index.js"

# ==============================================================
# DOCKER
# ==============================================================

if ! command -v docker >/dev/null 2>&1; then
  info "Instalando Docker..."
  apt-get update -qq && apt-get install -y -qq docker.io
  systemctl enable --now docker
fi

DOCKER_COMPOSE_CMD="docker compose"
docker compose version >/dev/null 2>&1 || DOCKER_COMPOSE_CMD="docker-compose"

if ! command -v nginx >/dev/null 2>&1; then
  info "Instalando nginx..."
  apt-get install -y -qq nginx
fi

# Nginx
info "Configurando Nginx..."
NGINX_LOCATIONS="/etc/nginx/${PROJECT_NAME}-locations.conf"

NGINX_ROOT=$(dirname "$INSTALL_DIR")
cat > "$NGINX_LOCATIONS" << NGINXEOF
location ${URL_PREFIX}/ {
    root ${NGINX_ROOT};
    try_files \$uri \$uri/ ${URL_PREFIX}/index.html;
}
location ${URL_PREFIX}/api/ {
    if (\$request_method = OPTIONS) {
        add_header Access-Control-Allow-Origin *;
        add_header Access-Control-Allow-Methods 'GET, POST, PUT, DELETE, OPTIONS';
        add_header Access-Control-Allow-Headers 'Content-Type, Authorization, X-Write-Key';
        add_header Access-Control-Max-Age 86400;
        add_header Content-Length 0;
        return 204;
    }
    add_header Access-Control-Allow-Origin * always;
    add_header Access-Control-Allow-Methods 'GET, POST, PUT, DELETE, OPTIONS' always;
    add_header Access-Control-Allow-Headers 'Content-Type, Authorization, X-Write-Key' always;
    proxy_pass http://127.0.0.1:${APP_PORT}/api/;
    proxy_http_version 1.1;
    proxy_set_header Host \$host;
    proxy_set_header X-Real-IP \$remote_addr;
    proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto \$scheme;
    proxy_buffering off;
    proxy_cache off;
    chunked_transfer_encoding off;
}
location ${URL_PREFIX}/data/ {
    if (\$request_method = OPTIONS) {
        add_header Access-Control-Allow-Origin *;
        add_header Access-Control-Allow-Methods 'GET, OPTIONS';
        add_header Access-Control-Allow-Headers 'Content-Type, Authorization';
        add_header Content-Length 0;
        return 204;
    }
    add_header Access-Control-Allow-Origin * always;
    proxy_pass http://127.0.0.1:${APP_PORT}/data/;
    proxy_http_version 1.1;
    proxy_set_header Host \$host;
    proxy_set_header X-Real-IP \$remote_addr;
}
location ${URL_PREFIX}/health {
    add_header Access-Control-Allow-Origin * always;
    proxy_pass http://127.0.0.1:${APP_PORT}/health;
    proxy_http_version 1.1;
    proxy_set_header Host \$host;
    proxy_set_header X-Real-IP \$remote_addr;
}
NGINXEOF

if [ -f /etc/nginx/sites-available/default ]; then
  if ! grep -q "${PROJECT_NAME}-locations.conf" /etc/nginx/sites-available/default; then
    sed -i "/^\s*server_name .*;$/a\    include ${NGINX_LOCATIONS};" /etc/nginx/sites-available/default
  fi
fi

# Replace __API_BASE__ placeholder
API_BASE_VAL="${URL_PREFIX}"
sed -i "s|__API_BASE__|$API_BASE_VAL|g" "$INSTALL_DIR/index.html"

# Build & start
info "Fazendo build..."
$DOCKER_COMPOSE_CMD -f "$INSTALL_DIR/docker-compose.yml" build

info "Iniciando containers..."
$DOCKER_COMPOSE_CMD -f "$INSTALL_DIR/docker-compose.yml" --project-name "$PROJECT_NAME" up -d

# Wait for API
