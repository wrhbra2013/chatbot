#!/bin/sh
set -eu

# ==============================================================
# Script de instalação — API E-commerce (Docker)
# Uso: sudo bash deploy.sh          (instalar)
#       sudo bash deploy.sh uninstall (desinstalar)
# ==============================================================

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
INSTALL_DIR="$SCRIPT_DIR"
NGINX_CONF="/etc/nginx/sites-available/default"
PROJECT_NAME="ecommerce"
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'
info()  { printf "${GREEN}[INFO]${NC} %s\n" "$1"; }
warn()  { printf "${YELLOW}[WARN]${NC} %s\n" "$1" >&2; }
error() { printf "${RED}[ERRO]${NC} %s\n" "$1" >&2; exit 1; }

[ "$(id -u)" -eq 0 ] || error "Execute como root: sudo bash deploy.sh"

uninstall() {
  echo ""
  info "===== Iniciando desinstalação ====="
  echo ""

  [ -f "$INSTALL_DIR/.env" ] && . "$INSTALL_DIR/.env" || true

  _dc_cmd="docker compose"
  docker compose version >/dev/null 2>&1 || _dc_cmd="docker-compose"

  info "[1/4] Parando containers..."
  $_dc_cmd -f "$INSTALL_DIR/docker-compose.yml" down -v 2>/dev/null && \
    info "Containers removidos" || warn "Falha ao derrubar containers"

  info "[2/4] Removendo nginx config..."
  NGINX_LOCATIONS="/etc/nginx/${PROJECT_NAME}-locations.conf"
  rm -f "$NGINX_LOCATIONS"
  sed -i "/${PROJECT_NAME}-locations.conf/d" "$NGINX_CONF" 2>/dev/null || true
  if nginx -t 2>/dev/null; then
    systemctl reload nginx.service 2>/dev/null && info "Nginx recarregado"
  fi

  info "[3/4] Removendo imagens..."
  docker images "${PROJECT_NAME}-api:latest" -q 2>/dev/null | xargs -r docker rmi 2>/dev/null || true

  info "[4/4] Concluído!"
}

case "${1:-}" in
  uninstall) uninstall; exit 0 ;;
esac

echo ""
info "===== Instalação do E-commerce API (Docker) ====="
echo ""

info "Verificando Docker..."
if ! command -v docker >/dev/null 2>&1; then
  info "Instalando Docker..."
  apt-get update -qq && apt-get install -y -qq docker.io
  systemctl enable --now docker
fi

DOCKER_COMPOSE_CMD="docker compose"
docker compose version >/dev/null 2>&1 || DOCKER_COMPOSE_CMD="docker-compose"

if ! command -v nginx >/dev/null 2>&1; then
  info "Instalando nginx..."
  apt-get install -y -qq nginx
fi

# Inputs
printf "Porta do app (host) [3000]: "; read -r APP_PORT
APP_PORT=${APP_PORT:-3000}

printf "Nome do banco [ecommerce_db]: "; read -r DB_NAME
DB_NAME=${DB_NAME:-ecommerce_db}

DB_USER=postgres
DB_PASS=wander
API_TOKEN=$(openssl rand -hex 32)

# .env
info "Criando .env"
cat > "$INSTALL_DIR/.env" <<ENVEOF
PORT=$APP_PORT
DB_NAME=$DB_NAME
DB_USER=$DB_USER
DB_PASS=$DB_PASS
API_TOKEN=$API_TOKEN
ENVEOF
chmod 600 "$INSTALL_DIR/.env"

# Nginx
info "Configurando Nginx..."
NGINX_LOCATIONS="/etc/nginx/${PROJECT_NAME}-locations.conf"
cat > "$NGINX_LOCATIONS" <<NGINXEOF
location /${PROJECT_NAME}/ {
    proxy_pass http://127.0.0.1:${APP_PORT}/;
    proxy_http_version 1.1;
    proxy_set_header Host \$host;
    proxy_set_header X-Real-IP \$remote_addr;
    proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto \$scheme;
}
NGINXEOF

if [ -f "$NGINX_CONF" ]; then
  if ! grep -q "${PROJECT_NAME}-locations.conf" "$NGINX_CONF"; then
    sed -i "/^\s*server_name .*;$/a\    include ${NGINX_LOCATIONS};" "$NGINX_CONF"
  fi
fi

# Docker Compose
info "Fazendo build..."
$DOCKER_COMPOSE_CMD -f "$INSTALL_DIR/docker-compose.yml" build

info "Iniciando containers..."
$DOCKER_COMPOSE_CMD -f "$INSTALL_DIR/docker-compose.yml" --project-name "$PROJECT_NAME" up -d

info "Aguardando API..."
sleep 5
for i in $(seq 1 30); do
  if curl -sf "http://127.0.0.1:$APP_PORT/health" >/dev/null 2>&1; then
    info "API saudável após ${i}s!"
    break
  fi
  sleep 1
done

if nginx -t 2>/dev/null; then
  systemctl reload nginx.service 2>/dev/null && info "Nginx recarregado"
fi

echo ""
info "===== Instalação concluída! ====="
echo ""
echo "  URL:     http://localhost:$APP_PORT/"
echo "  API:     http://localhost:$APP_PORT/health"
echo "  Token:   $API_TOKEN"
echo ""
echo "  Para acessar: http://SEU_IP/$PROJECT_NAME/"
echo ""
