#!/bin/bash
set -eu

# ==============================================================
# Instalador auto-contido — API + Frontend + WhatsApp Bot
# Cria todos os arquivos via heredoc no diretorio de destino.
# Uso: sudo bash install_chatbot [uninstall] [diretorio]
# ==============================================================

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'
info()  { printf "${GREEN}[INFO]${NC} %s\n" "$1"; }
warn()  { printf "${YELLOW}[WARN]${NC} %s\n" "$1" >&2; }
error() { printf "${RED}[ERRO]${NC} %s\n" "$1" >&2; exit 1; }

[ "$(id -u)" -eq 0 ] || error "Execute como root: sudo bash install_chatbot"

# ---- Uninstall ----
if [ "${1:-}" = "uninstall" ]; then
  UNINSTALL_DIR="${2:-/var/www/ecommerce}"
  info "===== Desinstalando $UNINSTALL_DIR ====="

  [ -d "$UNINSTALL_DIR" ] || error "Diretorio nao encontrado: $UNINSTALL_DIR"

  # Carrega .env se existir
  ENV_FILE="$UNINSTALL_DIR/.env"
  if [ -f "$ENV_FILE" ]; then
    set -a
    . "$ENV_FILE"
    set +a
  fi

  APP_PORT=${APP_PORT:-3000}
  DB_NAME=${DB_NAME:-ecommerce_db}
  DB_USER=${DB_USER:-postgres}
  DB_PASS=${DB_PASS:-postgres}
  PROJECT_NAME=$(basename "$UNINSTALL_DIR")
  CONTAINER_DB="${PROJECT_NAME}-db-1"

  # Drop database e tabelas (container ainda rodando)
  if command -v docker >/dev/null 2>&1; then
    if docker ps --format '{{.Names}}' 2>/dev/null | grep -qx "$CONTAINER_DB"; then
      info "Removendo database e tabelas do PostgreSQL..."
      docker exec "$CONTAINER_DB" psql -U "$DB_USER" -d postgres -c \
        "DROP DATABASE IF EXISTS \"$DB_NAME\" WITH (FORCE);" 2>/dev/null || true
    fi
  fi

  # Derruba containers
  if command -v docker >/dev/null 2>&1; then
    COMPOSE_FILE="$UNINSTALL_DIR/docker-compose.yml"
    if [ -f "$COMPOSE_FILE" ]; then
      info "Derrubando containers..."
      docker compose -f "$COMPOSE_FILE" --project-name "$PROJECT_NAME" down --volumes 2>/dev/null || \
      docker-compose -f "$COMPOSE_FILE" --project-name "$PROJECT_NAME" down --volumes 2>/dev/null || true
    fi
  fi

  # Mata processo na porta
  if command -v lsof >/dev/null 2>&1; then
    PID=$(lsof -ti tcp:"$APP_PORT" 2>/dev/null || true)
    if [ -n "$PID" ]; then
      info "Liberando porta $APP_PORT (PID $PID)..."
      kill -9 "$PID" 2>/dev/null || true
    fi
  fi

  # Remove config nginx
  NGINX_LOCATIONS="/etc/nginx/${PROJECT_NAME}-locations.conf"
  if [ -f "$NGINX_LOCATIONS" ]; then
    info "Removendo config nginx..."
    rm -f "$NGINX_LOCATIONS"
    if [ -f /etc/nginx/sites-available/default ]; then
      sed -i "\|include ${NGINX_LOCATIONS};|d" /etc/nginx/sites-available/default
    fi
    nginx -t 2>/dev/null && systemctl reload nginx.service 2>/dev/null || true
  fi

  # Remove diretorio
  info "Removendo $UNINSTALL_DIR..."
  rm -rf "$UNINSTALL_DIR"

  info "Desinstalacao concluida!"
  exit 0
fi

echo ""
info "===== Instalacao do Catalogo WhatsApp (Docker) ====="
echo ""

# Inputs
DEFAULT_DIR="/var/www/ecommerce"
printf "Diretorio de instalacao [${DEFAULT_DIR}]: "; read -r INSTALL_DIR
INSTALL_DIR=${INSTALL_DIR:-$DEFAULT_DIR}

printf "Porta do app (host) [3000]: "; read -r APP_PORT
APP_PORT=${APP_PORT:-3000}

printf "Nome do banco [ecommerce_db]: "; read -r DB_NAME
DB_NAME=${DB_NAME:-ecommerce_db}

printf "Dominio/Nginx path (ex: /ecommerce) [/]: "; read -r NGINX_PATH
NGINX_PATH=${NGINX_PATH:-/}

printf "Dominio externo (ex: api.projetosdinamicos.com.br) [api.projetosdinamicos.com.br]: "; read -r EXTERNAL_DOMAIN
EXTERNAL_DOMAIN=${EXTERNAL_DOMAIN:-api.projetosdinamicos.com.br}

PROJECT_NAME=$(basename "$INSTALL_DIR")

DB_USER=postgres
DB_PASS=$(openssl rand -hex 16)
API_TOKEN=$(openssl rand -hex 32)

mkdir -p "$INSTALL_DIR/api/src" "$INSTALL_DIR/static/css" "$INSTALL_DIR/static/js" "$INSTALL_DIR/data"

# ==============================================================
# ARQUIVOS VIA HEREDOC
# ==============================================================

  info "Criando docker-compose.yml..."
cat > "$INSTALL_DIR/docker-compose.yml" << DOCKERCOMPOSE
services:
  db:
    image: postgres:16-alpine
    environment:
      POSTGRES_DB: ${DB_NAME}
      POSTGRES_USER: ${DB_USER}
      POSTGRES_PASSWORD: ${DB_PASS}
    volumes:
      - pgdata:/var/lib/postgresql/data
    networks:
      - app-network
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DB_USER} -d ${DB_NAME}"]
      interval: 5s
      timeout: 5s
      retries: 10
      start_period: 30s

  api:
    build: api/
    ports:
      - "127.0.0.1:${APP_PORT}:${APP_PORT}"
    environment:
      PORT: ${APP_PORT}
      DB_HOST: db
      DB_PORT: 5432
      DB_NAME: ${DB_NAME}
      DB_USER: ${DB_USER}
      DB_PASS: ${DB_PASS}
      API_TOKEN: ${API_TOKEN}
    volumes:
      - ${INSTALL_DIR}/data:/app/data
    depends_on:
      db:
        condition: service_healthy
    networks:
      - app-network
    restart: unless-stopped

networks:
  app-network:
    driver: bridge

volumes:
  pgdata:
DOCKERCOMPOSE

info "Criando api/Dockerfile..."
cat > "$INSTALL_DIR/api/Dockerfile" << DOCKERFILE
FROM node:20-alpine
WORKDIR /app
COPY package.json ./
RUN npm install --production
COPY src/ ./src/
EXPOSE 3000
CMD ["node", "src/server.js"]
DOCKERFILE

info "Criando api/package.json..."
cat > "$INSTALL_DIR/api/package.json" << PKGJSON
{
  "name": "ecommerce-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "fastify": "^4.28.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "pg": "^8.12.0"
  }
}
PKGJSON

info "Criando .env..."
cat > "$INSTALL_DIR/.env" << ENVEOF
PORT=${APP_PORT}
DB_NAME=${DB_NAME}
DB_USER=${DB_USER}
DB_PASS=${DB_PASS}
API_TOKEN=${API_TOKEN}
EXTERNAL_DOMAIN=${EXTERNAL_DOMAIN}
NGINX_PATH=${NGINX_PATH}
ENVEOF
chmod 600 "$INSTALL_DIR/.env"

info "Criando api/src/server.js..."
cat > "$INSTALL_DIR/api/src/server.js" << 'SRVEOF'
import Fastify from 'fastify';
import cors from '@fastify/cors';
import rateLimit from '@fastify/rate-limit';
import pg from 'pg';
import 'dotenv/config';
import path from 'path';
import { fileURLToPath } from 'url';
import fs from 'fs';
import crypto from 'crypto';

const __dirname = path.dirname(fileURLToPath(import.meta.url));
const PROJECT_ROOT = path.resolve(__dirname, '..', '..');
const { Pool } = pg;

const fastify = Fastify({ logger: true });

const pool = new Pool({
  host: process.env.DB_HOST || 'localhost',
  port: parseInt(process.env.DB_PORT || '5432'),
  user: process.env.DB_USER || 'postgres',
  password: process.env.DB_PASS || 'postgres',
  database: process.env.DB_NAME || 'ecommerce_db',
});

pool.on('error', (err) => console.error('DB Error:', err));

const API_TOKEN = process.env.API_TOKEN || 'ecommerce-api-token';
const API_WRITE_KEY = process.env.API_WRITE_KEY || API_TOKEN;

await fastify.register(cors, {
  origin: true,
  methods: ['GET', 'POST', 'PUT', 'DELETE', 'OPTIONS'],
  allowedHeaders: ['Content-Type', 'Authorization', 'X-Write-Key'],
});

await fastify.register(rateLimit, {
  max: 100,
  timeWindow: '1 minute',
  keyGenerator: (req) => req.ip,
});

function validateTableName(table) {
  return /^[a-z_][a-z0-9_]{0,63}$/.test(table);
}
function validateId(id) {
  return /^[a-zA-Z0-9_-]{1,128}$/.test(id);
}

async function query(sql, params = []) {
  const client = await pool.connect();
  try {
    return await client.query(sql, params);
  } finally {
    client.release();
  }
}

const authMiddleware = async (req, reply) => {
  const token = req.headers.authorization?.replace('Bearer ', '');
  if (!token || token !== API_TOKEN) {
    reply.code(401).send({ success: false, error: 'Unauthorized' });
    return;
  }
};

const writeAuthMiddleware = async (req, reply) => {
  const writeKey = req.headers['x-write-key'];
  const authToken = req.headers.authorization?.replace('Bearer ', '');

  if (!writeKey && !authToken) {
    reply.code(403).send({ success: false, error: 'Write access denied' });
    return;
  }

  if (writeKey && writeKey !== API_WRITE_KEY) {
    reply.code(403).send({ success: false, error: 'Invalid write key' });
    return;
  }

  if (authToken && authToken !== API_TOKEN) {
    reply.code(403).send({ success: false, error: 'Invalid token' });
    return;
  }
};

fastify.get('/health', async () => {
  try {
    await pool.query('SELECT 1');
    return { status: 'healthy', database: 'connected', timestamp: new Date().toISOString() };
  } catch (err) {
    return { status: 'unhealthy', database: 'disconnected', error: err.message };
  }
});

fastify.get('/ping', async () => ({ pong: true }));

let botStatus = { qr: null, connected: false };

fastify.get('/api/qrcode', async () => botStatus);

fastify.post('/api/qrcode', { preHandler: writeAuthMiddleware }, async (req, res) => {
  const { qr, connected } = req.body || {};
  if (qr !== undefined) botStatus.qr = qr;
  if (connected !== undefined) botStatus.connected = connected;
  return { success: true };
