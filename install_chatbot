NGINX_BIN=$(command -v nginx || echo "/usr/sbin/nginx")
if [ -x "$NGINX_BIN" ]; then
  if "$NGINX_BIN" -t 2>/dev/null; then
    systemctl reload nginx.service 2>/dev/null && info "Nginx recarregado" || \
      "$NGINX_BIN" -s reload 2>/dev/null && info "Nginx recarregado"
  else
    warn "Config do nginx invalida. Execute manualmente: $NGINX_BIN -t"
  fi
